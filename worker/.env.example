# 이 파일을 복사해 .env 로 만들고 값을 채우세요.
#   cp .env.example .env
# 아래 "필수" 값이 하나라도 비어 있으면 앱 기동 시 RuntimeError로 즉시 종료됩니다.
# (배포 환경에서는 .env 파일 대신 플랫폼 환경변수로 주입하세요.)

# ===== 필수 (시크릿/인프라) =====
# Cloud Tasks 요청 인증용 내부 API 키
INTERNAL_API_KEY=
# 예: postgresql+psycopg2://user:password@host:5432/dbname
DATABASE_URL=
# S3 호환 스토리지 (Supabase Storage 등)
S3_BUCKET=
S3_ENDPOINT_URL=
S3_ACCESS_KEY=
S3_SECRET_KEY=
# Google Gemini API 키
GEMINI_API_KEY=

# ===== 선택 (미설정 시 주석의 기본값 사용) =====
# SERVICE_NAME=ai-server
# SERVICE_VERSION=0.1.0
# HOST=0.0.0.0
# PORT=8080
# S3_REGION=
# GEMINI_MODEL=gemini-2.5-flash
